# Admin PIN - change this to your desired PIN
# IMPORTANT: Using NEXT_PUBLIC_ exposes it to the browser.
# For production, validate the PIN server-side via /api/auth.
NEXT_PUBLIC_ADMIN_PIN=8080

# Google Apps Script endpoint exposing module JSON
NEXT_PUBLIC_MODULES_ENDPOINT=https://script.google.com/macros/s/AKfycbxQwKooZrZRsLJ1eLVqU33iI2oehKLYb5ip3tLkSrX7uaKi-8bFjuJ5vU1ZXCo9Tg9-_Q/exec

# Google Form embed URL (replace with your actual form URL)
NEXT_PUBLIC_GOOGLE_FORM_URL=https://docs.google.com/forms/d/e/1FAIpQLSdKzjaNiVQSLiptzWI79OWtulUSETxg6vFpCpq0hIn816z18A/viewform?embedded=true
